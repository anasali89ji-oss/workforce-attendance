# ===========================
# WORKFORCE PRO — ENV EXAMPLE
# ===========================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Auth (required — generate with: openssl rand -base64 32)
JWT_SECRET=your-min-32-char-secret-generate-with-openssl-rand

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Seed endpoint (optional — dev only)
SEED_SECRET=your-cryptographically-random-seed-secret
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=your-secure-seed-password
# Set to true ONLY if you need to seed production (dangerous)
# ALLOW_SEED_IN_PRODUCTION=false

# Upstash Redis (optional — for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Geofencing (optional — requires lat/lng configuration)
# GEOFENCE_ENABLED=false
# OFFICE_LAT=33.6844  (matches OFFICE_LAT in attendance route)
# OFFICE_LNG=73.0479
# GEOFENCE_RADIUS_METERS=200
