generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── TENANT ────────────────────────────────────────────────────────────────────
model Tenant {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  subdomain           String?  @unique
  logo_url            String?
  timezone            String   @default("UTC")
  working_hours_start String   @default("09:00")
  working_hours_end   String   @default("18:00")
  working_days        String[] @default(["MON","TUE","WED","THU","FRI"])
  late_threshold      Int      @default(15)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  profiles            Profile[]
  custom_roles        CustomRole[]
  departments         Department[]
  shifts              Shift[]
  leave_types         LeaveType[]
  announcements       Announcement[]
  kanban_boards       KanbanBoard[]
  setup_state         SetupWizardState?
  custom_fields       CustomField[]

  @@map("tenants")
}

// ─── PROFILE (was User) ────────────────────────────────────────────────────────
model Profile {
  id            String   @id @default(uuid())
  tenant_id     String
  email         String
  password_hash String
  full_name     String?
  first_name    String?
  last_name     String?
  phone         String?
  avatar_url    String?
  role          String   @default("worker")
  department    String?
  position      String?
  employee_id   String?
  base_salary   Float?
  is_active     Boolean  @default(true)
  joining_date  DateTime? @db.Date
  joined_at     DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant                   Tenant                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  attendance_logs          AttendanceLog[]
  leave_requests           LeaveRequest[]             @relation("EmployeeLeaveRequests")
  leave_approvals          LeaveRequest[]             @relation("ApproverLeaveRequests")
  leave_balances           LeaveBalance[]
  kanban_assignments       KanbanCardAssignment[]
  notifications            Notification[]
  audit_logs               AuditLog[]
  invitations_sent         TeamInvitation[]           @relation("InvitedBy")
  break_logs               BreakLog[]
  payroll_records          PayrollRecord[]
  overtime_requests        OvertimeRequest[]
  work_schedules           WorkSchedule[]
  custom_field_values      EmployeeCustomFieldValue[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([email])
  @@map("profiles")
}

// ─── CUSTOM ROLE ───────────────────────────────────────────────────────────────
model CustomRole {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  slug        String
  description String?
  color       String   @default("#6366f1")
  permissions String[] @default([])
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@map("custom_roles")
}

// ─── DEPARTMENT ────────────────────────────────────────────────────────────────
model Department {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  head_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("departments")
}

// ─── SHIFT ─────────────────────────────────────────────────────────────────────
model Shift {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  start_time  String
  end_time    String
  color       String   @default("#3b82f6")
  is_night    Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  work_schedules  WorkSchedule[]
  attendance_logs AttendanceLog[]

  @@index([tenant_id])
  @@map("shifts")
}

// ─── WORK SCHEDULE ─────────────────────────────────────────────────────────────
model WorkSchedule {
  id             String    @id @default(uuid())
  tenant_id      String
  user_id        String
  shift_id       String
  day_of_week    String
  effective_from DateTime
  effective_to   DateTime?
  created_at     DateTime  @default(now())

  shift Shift   @relation(fields: [shift_id], references: [id])
  user  Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("work_schedules")
}

// ─── ATTENDANCE LOG ────────────────────────────────────────────────────────────
model AttendanceLog {
  id                   String    @id @default(uuid())
  tenant_id            String
  user_id              String
  shift_id             String?
  attendance_date      DateTime  @db.Date
  punch_in_at          DateTime?
  punch_out_at         DateTime?
  status               String    @default("punched_in")
  is_late              Boolean   @default(false)
  late_minutes         Int       @default(0)
  is_overtime          Boolean   @default(false)
  overtime_minutes     Int       @default(0)
  net_duration_minutes Int       @default(0)
  timesheet_note       String?
  ip_address           String?
  location_lat         Float?
  location_lng         Float?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  user   Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shift  Shift?   @relation(fields: [shift_id], references: [id])
  breaks BreakLog[]

  @@unique([user_id, attendance_date])
  @@index([tenant_id])
  @@index([user_id])
  @@index([attendance_date])
  @@index([status])
  @@map("attendance_logs")
}

// ─── BREAK LOG ─────────────────────────────────────────────────────────────────
model BreakLog {
  id               String    @id @default(uuid())
  attendance_id    String
  user_id          String
  break_start      DateTime
  break_end        DateTime?
  duration_minutes Int?
  break_type       String    @default("regular")
  created_at       DateTime  @default(now())

  attendance AttendanceLog @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  user       Profile       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("break_logs")
}

// ─── LEAVE TYPE ────────────────────────────────────────────────────────────────
model LeaveType {
  id                String   @id @default(uuid())
  tenant_id         String
  name              String
  code              String
  color             String   @default("#10b981")
  days_per_year     Int      @default(0)
  carry_forward     Boolean  @default(false)
  requires_approval Boolean  @default(true)
  created_at        DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  leave_requests LeaveRequest[]
  leave_balances LeaveBalance[]

  @@index([tenant_id])
  @@map("leave_types")
}

// ─── LEAVE REQUEST ─────────────────────────────────────────────────────────────
model LeaveRequest {
  id               String    @id @default(uuid())
  tenant_id        String
  user_id          String
  approved_by      String?
  leave_type_id    String?
  leave_type       String?
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  days_count       Float
  reason           String?
  status           String    @default("pending")
  approved_at      DateTime?
  rejected_at      DateTime?
  rejection_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user           Profile    @relation("EmployeeLeaveRequests", fields: [user_id], references: [id], onDelete: Cascade)
  approver       Profile?   @relation("ApproverLeaveRequests", fields: [approved_by], references: [id])
  leave_type_rel LeaveType? @relation(fields: [leave_type_id], references: [id])

  @@index([tenant_id])
  @@index([user_id])
  @@index([status])
  @@map("leave_requests")
}

// ─── LEAVE BALANCE ─────────────────────────────────────────────────────────────
model LeaveBalance {
  id            String   @id @default(uuid())
  tenant_id     String
  user_id       String
  leave_type_id String
  year          Int
  total_days    Float    @default(0)
  used_days     Float    @default(0)
  pending_days  Float    @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leave_type LeaveType @relation(fields: [leave_type_id], references: [id])

  @@unique([user_id, leave_type_id, year])
  @@index([tenant_id])
  @@map("leave_balances")
}

// ─── KANBAN ────────────────────────────────────────────────────────────────────
model KanbanBoard {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  created_by  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  columns KanbanColumn[]

  @@index([tenant_id])
  @@map("kanban_boards")
}

model KanbanColumn {
  id         String   @id @default(uuid())
  board_id   String
  name       String
  color      String   @default("#6366f1")
  position   Int      @default(0)
  created_at DateTime @default(now())

  board KanbanBoard  @relation(fields: [board_id], references: [id], onDelete: Cascade)
  cards KanbanCard[]

  @@map("kanban_columns")
}

model KanbanCard {
  id          String    @id @default(uuid())
  column_id   String
  title       String
  description String?
  priority    String    @default("medium")
  due_date    DateTime?
  position    Int       @default(0)
  labels      String[]  @default([])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  column      KanbanColumn           @relation(fields: [column_id], references: [id], onDelete: Cascade)
  assignments KanbanCardAssignment[]

  @@map("kanban_cards")
}

model KanbanCardAssignment {
  id         String   @id @default(uuid())
  card_id    String
  user_id    String
  created_at DateTime @default(now())

  card KanbanCard @relation(fields: [card_id], references: [id], onDelete: Cascade)
  user Profile    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([card_id, user_id])
  @@map("kanban_card_assignments")
}

// ─── NOTIFICATION ──────────────────────────────────────────────────────────────
model Notification {
  id         String   @id @default(uuid())
  tenant_id  String
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  is_read    Boolean  @default(false)
  action_url String?
  created_at DateTime @default(now())

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([tenant_id])
  @@map("notifications")
}

// ─── AUDIT LOG ─────────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String?
  action      String
  entity_type String
  entity_id   String?
  old_values  Json?
  new_values  Json?
  ip_address  String?
  created_at  DateTime @default(now())

  user Profile? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([user_id])
  @@map("audit_logs")
}

// ─── ANNOUNCEMENT ──────────────────────────────────────────────────────────────
model Announcement {
  id         String    @id @default(uuid())
  tenant_id  String
  title      String
  content    String
  priority   String    @default("normal")
  author_id  String
  expires_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("announcements")
}

// ─── PAYROLL ───────────────────────────────────────────────────────────────────
model PayrollRecord {
  id           String    @id @default(uuid())
  tenant_id    String
  user_id      String
  period_start DateTime  @db.Date
  period_end   DateTime  @db.Date
  base_salary     Float
  overtime_pay    Float     @default(0)
  deductions      Float     @default(0)
  bonuses         Float     @default(0)
  net_pay         Float
  total_hours     Float     @default(0)
  overtime_hours  Float     @default(0)
  working_days    Int       @default(0)
  status          String    @default("draft")
  processed_at DateTime?
  created_at   DateTime  @default(now())

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id, period_start])
  @@index([tenant_id])
  @@index([user_id])
  @@map("payroll_records")
}

// ─── OVERTIME ──────────────────────────────────────────────────────────────────
model OvertimeRequest {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String
  date        DateTime @db.Date
  hours       Float
  reason      String?
  status      String   @default("pending")
  approved_by String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([user_id])
  @@map("overtime_requests")
}

// ─── TEAM INVITATION ───────────────────────────────────────────────────────────
model TeamInvitation {
  id          String    @id @default(uuid())
  tenant_id   String
  email       String
  role_id     String?
  invited_by  String
  token       String    @unique @default(uuid())
  status      String    @default("pending")
  expires_at  DateTime
  accepted_at DateTime?
  created_at  DateTime  @default(now())

  inviter Profile @relation("InvitedBy", fields: [invited_by], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("team_invitations")
}

// ─── SETUP WIZARD STATE ────────────────────────────────────────────────────────
model SetupWizardState {
  id          String   @id @default(uuid())
  tenant_id   String   @unique
  step        Int      @default(1)
  is_complete Boolean  @default(false)
  data        Json     @default("{}")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("setup_wizard_state")
}

// ─── CUSTOM FIELDS ─────────────────────────────────────────────────────────────
model CustomField {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  field_key   String
  field_type  String   @default("text")
  is_required Boolean  @default(false)
  options     String[] @default([])
  created_at  DateTime @default(now())

  tenant Tenant                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  values EmployeeCustomFieldValue[]

  @@map("custom_fields")
}

model EmployeeCustomFieldValue {
  id              String   @id @default(uuid())
  custom_field_id String
  user_id         String
  value           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  custom_field CustomField @relation(fields: [custom_field_id], references: [id], onDelete: Cascade)
  user         Profile     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([custom_field_id, user_id])
  @@map("employee_custom_field_values")
}
